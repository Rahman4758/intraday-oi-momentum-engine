# =============================================================================
# Institutional Momentum Trading System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Upstox API Credentials ---
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here
UPSTOX_REDIRECT_URI=http://localhost:8000/callback

# --- MongoDB Connection ---
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=intraday_momentum

# --- Capital & Risk Management ---
CAPITAL=100000
MAX_RISK_PER_TRADE=1000
MAX_DAILY_LOSS=3000
MAX_CONSECUTIVE_LOSSES=3

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
